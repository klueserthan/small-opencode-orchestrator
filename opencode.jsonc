{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@mohak34/opencode-notifier@latest"
  ],
  // Local plugins in ~/.config/opencode/plugins/ load automatically (e.g. plan-post-approval.ts).
  "provider": {
    "opencode": {},
    "deepseek": {
      "models": {
        "deepseek-v4-pro": {
          "interleaved": {
            "field": "reasoning_content",
          },
        },
      },
    },
  },
  "default_agent": "orchestrator",
  "share": "manual",
  "autoupdate": true,
  // Minimal workspace baseline; per-agent tool policy lives in agents/<id>.md frontmatter. If you want it more permissive you can copy to your project workspace ./opencode/opencode.jsonc with "allow" instead
  "permission": {
    "bash": {
      "*": "ask",
    },
    "edit": "ask",
  },
  // Strong models for the primary agents
  "agent": {
    "build": {
      "model": "opencode-go/deepseek-v4-pro",
      "reasoningEffort": "max",
      "textVerbosity": "medium",
    },
    "plan": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "high",
      "textVerbosity": "medium",
    },
    "orchestrator": {
      // plan-post-approval plugin reads this path only (not merged from agent frontmatter).
      "plan_post_approval_handoff_agent": "orchestrator",
      "model": "openai/gpt-5.5",
      "reasoningEffort": "xhigh",
      "textVerbosity": "medium",
      "temperature": 0.2,
    },
    "plan-runner": {
      // stick with pro here aswell if you accept the speed vs quality tradeoff
      "model": "opencode-go/deepseek-v4-pro",
      "reasoningEffort": "max",
      "textVerbosity": "medium",
      "temperature": 0.2,
    },
    // Cheap model for subagents (defined in agents/<id>.md)
    "code-explorer": {
      "reasoningEffort": "max",
      "textVerbosity": "medium",
      "temperature": 0.2,
    },
    "code-executor": {
      "reasoningEffort": "max",
      "textVerbosity": "medium",
    },
    "test-verifier": {
      "reasoningEffort": "max",
      "textVerbosity": "medium",
    },
    "spec-critic": {
      "reasoningEffort": "max",
      "textVerbosity": "medium",
    },
    "security-reviewer": {
      "reasoningEffort": "max",
      "textVerbosity": "medium",
    },
    "docs-reviewer": {
      "reasoningEffort": "max",
      "textVerbosity": "medium",
    },
    "code-reviewer": {
      "reasoningEffort": "max",
      "textVerbosity": "medium",
    },
    "api-docs-researcher": {
      "reasoningEffort": "max",
      "textVerbosity": "medium",
    },
    "host-security-investigator": {
      "reasoningEffort": "max",
      "textVerbosity": "medium",
    },
  },
  "formatter": true,
}